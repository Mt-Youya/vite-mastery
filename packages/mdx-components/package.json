{
  "name": "@vite-mastery/mdx-components",
  "private": true,
  "version": "0.0.0",
  "description": "MDX 通用组件(Callout/CodeGroup/Steps/Tabs/Diff/Detail)+ Shiki 代码高亮",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./shiki": {
      "types": "./src/shiki.ts",
      "default": "./src/shiki.ts"
    },
    "./use-mdx-components": {
      "types": "./src/use-mdx-components.tsx",
      "default": "./src/use-mdx-components.tsx"
    }
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@vite-mastery/ui": "workspace:*",
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.0.0",
    "shiki": "^4.0.0",
    "@shikijs/twoslash": "^4.0.0",
    "@shikijs/transformers": "^4.0.0"
  },
  "peerDependencies": {
    "@mdx-js/react": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vite-mastery/tsconfig": "workspace:*",
    "@vitejs/plugin-react": "^6.0.0",
    "rimraf": "^6.0.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.0",
    "vite-plugin-dts": "^5.0.0"
  }
}
