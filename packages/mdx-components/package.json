{
  "name": "@vite-mastery/mdx-components",
  "version": "0.0.1",
  "private": true,
  "description": "MDX 通用组件(Callout/CodeGroup/Steps/Tabs/Diff/Detail)+ Shiki 代码高亮",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./shiki": "./src/libs/shiki.ts",
    "./use-mdx-components": "./src/components/use-mdx-components.tsx",
    "./style.css": "./src/styles/global.css"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.2.1",
    "@hugeicons/react": "^1.1.9",
    "@shikijs/transformers": "^4.3.0",
    "@shikijs/twoslash": "^4.3.0",
    "@vite-mastery/ui": "workspace:*",
    "shadcn": "^4.11.0",
    "shiki": "^4.3.0"
  },
  "devDependencies": {
    "@types/mdx": "^2.0.14",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-mastery/tsconfig": "workspace:*",
    "@vitejs/plugin-react": "^6.0.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  },
  "peerDependencies": {
    "@mdx-js/react": "^3.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
