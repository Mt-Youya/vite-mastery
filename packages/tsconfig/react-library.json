{
  "$schema": "https://json.schemastore.org/tsconfig",
  "display": "vite-mastery React library",
  "extends": "./base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "ES2023"],
    "jsx": "preserve",
