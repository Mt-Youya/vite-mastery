{
  "name": "@vite-mastery/ui",
  "version": "0.0.1",
  "private": true,
  "description": "Base UI primitive + Tailwind 设计 token,vite-mastery 内部组件库",
  "type": "module",
  "sideEffects": [
    "**/*.css"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./lib/*": "./src/lib/*.ts",
    "./hooks/*": "./src/hooks/*.ts",
    "./*": "./src/components/*.tsx",
    "./style.css": "./src/styles/global.css"
  },
  "scripts": {
    "build": "vite build && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist .turbo"
  },
  "dependencies": {
    "@base-ui/react": "1.6.0",
    "@hugeicons/core-free-icons": "^4.2.1",
    "@hugeicons/react": "^1.1.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vite-mastery/tsconfig": "workspace:*",
    "@vitejs/plugin-react": "^6.0.3",
    "rimraf": "^6.1.3",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "vite-plugin-dts": "^5.0.3"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}
