{
  "extends": "@vite-mastery/tsconfig/nextjs",
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules", ".next"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./*"]
    },
    "incremental": true,
    "noEmit": true
  }
}
