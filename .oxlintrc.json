{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn",
    "restriction": "off",
    "pedantic": "off",
    "style": "off",
    "nursery": "off"
  },
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "ignorePatterns": [
    "node_modules",
    "dist",
    "build",
    "out",
    ".next",
    ".turbo",
    ".content-collections",
    "coverage",
    "*.d.ts"
  ],
  "rules": {
    "no-console": "off",
    "no-debugger": "error"
  }
}
