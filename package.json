{
  "name": "vite-mastery",
  "version": "0.0.1",
  "private": false,
  "description": "中文社区第一份「Vite 核心机制 + 插件/Hooks 深度」的系统化学习指南",
  "keywords": [
    "Chinese",
    "docs",
    "vite"
  ],
  "author": "Cyrus Doyle",
  "type": "module",
  "devDependencies": {
    "@types/node": "^26.0.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "scripts": {
    "dev": "pnpm --filter @vite-mastery/web dev",
    "dev:web": "pnpm --filter @vite-mastery/web dev",
    "dev:playground": "pnpm --filter @vite-mastery/playground dev",
    "dev:all": "pnpm -r --parallel --if-present run dev",
    "build": "pnpm -r --if-present run build",
    "build:web": "pnpm --filter @vite-mastery/web build",
    "build:playground": "pnpm --filter @vite-mastery/playground build",
    "start": "pnpm -r --if-present run start",
    "start:web": "pnpm --filter @vite-mastery/web start",
    "start:playground": "pnpm --filter @vite-mastery/playground start",
    "preview:web": "pnpm build:web && pnpm start:web",
    "preview:playground": "pnpm build:playground && pnpm start:playground",
    "lint": "oxlint .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "typecheck": "pnpm -r --if-present run typecheck",
    "clean": "pnpm -r --if-present run clean",
    "new:doc": "node --experimental-strip-types scripts/new-doc.ts",
    "new:example": "node --experimental-strip-types scripts/new-example.ts",
    "new:v7note": "node --experimental-strip-types scripts/new-v7note.ts",
    "check:content": "node --experimental-strip-types scripts/check-content.ts",
    "fix:tw": "node --experimental-strip-types scripts/fix-tw-classes.ts",
    "fix:tw:preview": "node --experimental-strip-types scripts/fix-tw-classes.ts -- --dry-run"
  },
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
